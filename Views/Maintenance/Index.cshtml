@model IEnumerable<NetworkManager.Models.MaintenanceLog>
@using NetworkManager.Models
@{
    ViewData["Title"] = "ประวัติการดูแลรักษา";
}

<div class="page-header">
    <h2><i class="bi bi-tools me-2 text-primary"></i>ประวัติการดูแลรักษา</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> บันทึกใหม่
    </a>
</div>

<!-- Filter -->
<form method="get" class="filter-bar">
    <div>
        <label class="form-label mb-1">กรองตามอุปกรณ์</label>
        <select name="deviceId" class="form-select" asp-items="ViewBag.DeviceList" style="width:200px">
            <option value="">อุปกรณ์ทั้งหมด</option>
        </select>
    </div>
    <div>
        <label class="form-label mb-1">ประเภทงาน</label>
        <select name="workType" class="form-select" style="width:160px">
            <option value="">ทั้งหมด</option>
            @foreach (var wt in Enum.GetValues<WorkType>())
            {
                <option value="@wt" selected="@(ViewBag.WorkType == wt.ToString() ? "selected" : null)">@wt</option>
            }
        </select>
    </div>
    <div class="d-flex gap-2 align-items-end">
        <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> กรอง</button>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-circle"></i> ล้าง</a>
    </div>
</form>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-journal-text"></i>
                <p>ยังไม่มีบันทึกการดูแลรักษา</p>
                <a asp-action="Create" class="btn btn-primary mt-3">
                    <i class="bi bi-plus-circle"></i> เพิ่มบันทึกแรก
                </a>
            </div>
        }
        else
        {
            <table class="table-custom w-100">
                <thead>
                    <tr>
                        <th>วันที่</th>
                        <th>อุปกรณ์</th>
                        <th>ประเภทงาน</th>
                        <th>ผู้ดำเนินการ</th>
                        <th>รายละเอียด</th>
                        <th style="width:100px">จัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td style="white-space:nowrap">@log.Date.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-controller="Devices" asp-action="Details" asp-route-id="@log.DeviceId"
                                   class="text-decoration-none text-primary">
                                    @log.Device?.Name
                                </a>
                            </td>
                            <td>
                                <span class="work-badge work-@log.WorkType.ToString().ToLower()">
                                    @log.WorkType
                                </span>
                            </td>
                            <td>@log.Technician</td>
                            <td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                                title="@log.Description">
                                @log.Description
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Edit" asp-route-id="@log.Id"
                                       class="btn btn-sm btn-outline-secondary" title="แก้ไข">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@log.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger"
                                                onclick="return confirm('ลบบันทึกนี้?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
