<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — NetManager</title>
    <meta name="description" content="ระบบบริหารจัดการอุปกรณ์เครือข่ายและเซิร์ฟเวอร์ส่วนตัว" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&family=IBM+Plex+Mono&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="app-wrapper">
            <!-- Sidebar -->
            <nav class="sidebar" id="sidebar">
                <div class="sidebar-brand">
                    <i class="bi bi-diagram-3-fill brand-icon"></i>
                    <span class="brand-text">NetManager</span>
                </div>

                <ul class="sidebar-nav">
                    <li class="nav-section-label">ภาพรวม</li>
                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                        <a asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <li class="nav-section-label">จัดการอุปกรณ์</li>
                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Devices" ? "active" : "")">
                        <a asp-controller="Devices" asp-action="Index">
                            <i class="bi bi-hdd-rack-fill"></i>
                            <span>อุปกรณ์ทั้งหมด</span>
                        </a>
                    </li>
                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "IpAddress" ? "active" : "")">
                        <a asp-controller="IpAddress" asp-action="Index">
                            <i class="bi bi-ethernet"></i>
                            <span>IP Address (IPAM)</span>
                        </a>
                    </li>
                    <li class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Maintenance" ? "active" : "")">
                        <a asp-controller="Maintenance" asp-action="Index">
                            <i class="bi bi-tools"></i>
                            <span>ประวัติการดูแล</span>
                        </a>
                    </li>
                </ul>

                <div class="sidebar-footer">
                    <div class="user-info">
                        <div class="user-avatar">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div>
                            <div class="user-name">@User.Identity!.Name</div>
                            <div class="user-role">Administrator</div>
                        </div>
                    </div>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-logout" title="ออกจากระบบ">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>
            </nav>

            <!-- Main Content -->
            <div class="main-content">
                <header class="topbar">
                    <button class="sidebar-toggle" id="sidebarToggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <h1 class="page-title">@ViewData["Title"]</h1>
                    <div class="topbar-right">
                        <span class="ping-badge">
                            <i class="bi bi-arrow-repeat"></i>
                            Auto Ping: ทุก 5 นาที
                        </span>
                    </div>
                </header>

                <div class="content-area">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @RenderBody()
                </div>
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
